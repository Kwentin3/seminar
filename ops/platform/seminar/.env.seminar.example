# Seminar Docker attachment environment (production-ready example)
# This env file shape matches the active live deploy control plane on the VPS.
# Default production path is Docker + Traefik under /opt/seminar, not legacy systemd.
#
# Required artifact/deploy coordinates
SEMINAR_IMAGE=ghcr.io/kwentin3/seminar@sha256:<pinned_digest>
BUILD_ID=<commit_sha>
SEMINAR_DATA_DIR=/opt/seminar/parity-data

# Required Traefik routing contract (no domain hardcode in compose)
APP_ROUTER_NAME=seminar
APP_HOST_RULE=Host(`seminar-ai.ru`) || Host(`www.seminar-ai.ru`)
APP_SERVICE_PORT=8787
TRAEFIK_CERTRESOLVER=le
TRAEFIK_ENTRYPOINTS_WEB=web
TRAEFIK_ENTRYPOINTS_WEBSECURE=websecure

# Optional routing switches
# 1 -> declare intent to redirect www->apex; 0 -> do not use www redirect middleware
APP_ENABLE_WWW_REDIRECT=1
# Apex host for www redirect middleware replacement
APP_WWW_REDIRECT_TO=seminar-ai.ru
# Optional middlewares for websecure router.
# If APP_ENABLE_WWW_REDIRECT=1 set:
APP_MIDDLEWARES=seminar-www-redirect
# If APP_ENABLE_WWW_REDIRECT=0 set:
# APP_MIDDLEWARES=

# Staging example (override only these keys, no compose edits):
# APP_HOST_RULE=Host(`staging-seminar-ai.ru`)
# APP_WWW_REDIRECT_TO=staging-seminar-ai.ru
